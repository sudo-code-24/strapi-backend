{
  "kind": "singleType",
  "collectionName": "school_profile",
  "info": {
    "singularName": "school-profile",
    "pluralName": "school-profiles",
    "displayName": "School Profile"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "tagline": {
      "type": "string"
    },
    "heroQuote": {
      "type": "string"
    },
    "heroHeading": {
      "type": "text"
    },
    "heroDescription": {
      "type": "text"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "schoolInfoImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "showcaseFeatures": {
      "type": "component",
      "repeatable": true,
      "component": "school.home-feature"
    },
    "history": {
      "type": "richtext"
    },
    "mission": {
      "type": "richtext"
    },
    "vision": {
      "type": "richtext"
    },
    "phone": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "address": {
      "type": "text"
    },
    "officeHours": {
      "type": "string"
    },
    "facebookUrl": {
      "type": "string"
    }
  }
}
